    {
        "level": 3,
        "type": "tips",
        "label": "Grammar & Tips",
        "description": "Essential grammatical rules for understanding Telugu pronouns and proximity.",
        "items": [
            {
                "id": "proximity_rule",
                "title": "The 'A' vs 'I' Sound Rule",
                "body": "Most 3rd-person pronouns in Telugu come in pairs based on distance. Pronouns starting with 'A' refer to someone or something distant (like 'That'), while pronouns starting with 'I' refer to someone or something close (like 'This').",
                "example": {
                    "english": "That is a student / This is a student",
                    "telugu": "అతను విద్యార్థి / ఇతను విద్యార్థి",
                    "phonetic": "Atanu vidyārthi / Itanu vidyārthi"
                },
                "category": "Grammar"
            },
            {
                "id": "loanword_pluralization",
                "title": "Pluralizing English Loanwords",
                "body": "When using English words in Telugu, we often append a vowel like 'u' to the end to adapt them to Telugu phonology before adding grammatical suffixes like the plural 'lu'.",
                "example": {
                    "english": "Car / Cars",
                    "telugu": "కారు / కారులు",
                    "phonetic": "Cāru / Cārulu"
                },
                "category": "Vocabulary"
            }
        ]
    }
